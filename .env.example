# SECURITY
# ✓ This file is gitignored — the flag is never committed to the repo.
# ✓ Without this flag the bypass is completely inactive (dead code).
# ✓ Only private RFC-1918 / loopback addresses are affected.
# ✓ Public internet IPs always go through the normal auth flow.
# ✗ NEVER set MOBILE_DEBUG=true on a production or internet-facing server.
# ✗ NEVER commit real secrets.
#
APP_BASE_URL=http://localhost:3000
PORT=3000
DATABASE_PATH=./database.sqlite
NODE_ENV='development'

# ── mobileDebug — LOCAL NETWORK AUTH BYPASS ───────────────────────────────────
#
# Set to true ONLY on a local development machine to allow LAN devices
# (phones, tablets) to access the canvas without logging in.
#
# HOW IT WORKS
# When MOBILE_DEBUG=true, requests arriving from private/loopback IPs
# (127.x, 10.x, 172.16-31.x, 192.168.x) are given an anonymous session
# (username: anon-<last-octet>) and bypass the login overlay entirely.
# The client reads a data attribute injected by the server, so no IP
# ranges are hardcoded in the public JavaScript bundle.
# ✗ NEVER set MOBILE_DEBUG=true on a production or internet-facing server.
MOBILE_DEBUG=false

# hCaptcha — get keys at https://dashboard.hcaptcha.com
HCAPTCHA_SITEKEY=
HCAPTCHA_SECRET=

# Email (SMTP) — used for account verification
RESEND_API_KEY=
EMAIL_FROM=Saint-Pixels <no-reply@saint-pixels.org>

# Base URL for verification links
APP_BASE_URL=https://www.saint-pixels.org/

# Timelapse
FFMPEG_PATH=
TIMELAPSE_SECRET=
TIMELAPSE_OUT_DIR=
JSON_HISTORY_PATH=